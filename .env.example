# Required: Postgres connection string
DATABASE_URL=postgres://voiceflow:voiceflow@127.0.0.1:5432/voiceflow

# Optional: change backend bind host/port
HOST=127.0.0.1
PORT=8000

# Optional: weather questions without a city (weather requires internet)
# DEFAULT_CITY=Hyderabad

# Optional: Gemini fallback for general questions (requires internet + key)
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-flash-latest
# GEMINI_ENABLED=0

# Optional: Gemini language detection (off by default)
# GEMINI_LANG_DETECT=0

# Optional: Hugging Face Whisper voice transcription (requires internet + token)
# HF_TOKEN=your_huggingface_token
# HF_WHISPER_MODEL=openai/whisper-large-v3
# HF_PROVIDER=hf-inference
# HF_TRANSLATE_MODEL=
# HF_LANGID_MODEL=papluca/xlm-roberta-base-language-detection
# HF_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# HF_AUDIO_LID_MODEL=facebook/mms-lid-126

# Optional: override message when Gemini quota/rate limit is hit
# FALLBACK_LIMIT_EXCEEDED_MESSAGE=AI fallback is rate-limited or quota-exhausted right now. Please wait and try again.
